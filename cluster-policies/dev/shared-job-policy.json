{
  "cluster_type": {
    "type": "fixed",
    "value": "job",
    "hidden": true
  },
  "spark_version": {
    "type": "fixed",
    "value": "auto:latest-lts",
    "hidden": true
  },
  "runtime_engine": {
    "type": "fixed",
